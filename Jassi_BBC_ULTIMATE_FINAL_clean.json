    {
      "parameters": {
        "jsCode": "function cleanDate(val) {\n  if (!val || val === 'null' || val === 'undefined' || val.trim() === '') return null;\n  const v = val.trim();\n  if (v.includes('/')) {\n    const parts = v.split('/');\n    if (parts.length === 3) return parts[2]+'-'+parts[1].padStart(2,'0')+'-'+parts[0].padStart(2,'0');\n  }\n  if (v.includes('-') && v.length === 10) return v;\n  return null;\n}\nfunction cleanVal(val) {\n  if (!val || val === 'null' || val === 'undefined' || val.trim() === '') return null;\n  return val.trim();\n}\nfunction cleanNum(val) {\n  if (!val || val === 'null' || val === 'undefined') return null;\n  const n = parseFloat(String(val).replace(/[^0-9.]/g,''));\n  return isNaN(n) ? null : n;\n}\n\nconst brainOutput = $('Jassi Brain').first().json;\nlet rawReply = '';\ntry { rawReply = brainOutput.content[0].text; } catch(e) { rawReply = 'System error. Try again.'; }\n\nlet replyText = rawReply.replace(/\\|\\|ACTION[\\s\\S]*?\\|\\|/g, '').trim();\nconst actionMatch = rawReply.match(/\\|\\|ACTION([\\s\\S]*?)\\|\\|/);\nlet hasAction = false, supabaseTable = '', supabasePayload = '{}', isNewRecord = false, isAllPaid = false;\nlet lorryNumber = $('Parse Input').first().json.lorryNumber || '';\nlet tripDate = new Date().toISOString().split('T')[0];\nlet tripRate = null, tripCommission = null, commissionStatus = 'pending';\n\nif (actionMatch) {\n  hasAction = true;\n  const fullAction = 'ACTION' + actionMatch[1];\n  const parts = fullAction.split('|');\n  const actionType = parts[0].replace('ACTION:', '').trim();\n  const kv = {};\n  parts.slice(1).forEach(p => {\n    const idx = p.indexOf(':');\n    if (idx > -1) kv[p.substring(0,idx).trim()] = p.substring(idx+1).trim();\n  });\n\n  lorryNumber = cleanVal(kv['LORRY']) || lorryNumber;\n\n  if (actionType === 'NEW_TRIP') {\n    supabaseTable = 'trips'; isNewRecord = true;\n    tripDate = cleanDate(kv['DATE']) || new Date().toISOString().split('T')[0];\n    tripRate = cleanNum(kv['RATE']);\n    tripCommission = cleanNum(kv['COMMISSION']);\n    commissionStatus = tripCommission ? 'pending' : null;\n    supabasePayload = JSON.stringify({\n      lorry_number: cleanVal(kv['LORRY']),\n      loading_point: 'Bangalore',\n      unloading_point: cleanVal(kv['TO']),\n      party_name: cleanVal(kv['PARTY']),\n      rate: tripRate,\n      loaded_date: tripDate,\n      expected_arrival_date: cleanDate(kv['ARRIVAL']),\n      trip_status: 'active',\n      commission_amount: tripCommission,\n      commission_status: commissionStatus,\n      driver_phone: cleanVal(kv['DPHONE'])\n    });\n  } else if (actionType === 'NEW_DRIVER') {\n    supabaseTable = 'drivers'; isNewRecord = true;\n    supabasePayload = JSON.stringify({\n      name: cleanVal(kv['NAME']),\n      phone: cleanVal(kv['PHONE']),\n      vehicle_number: cleanVal(kv['TRUCK'])\n    });\n  } else if (actionType === 'ARRIVED') {\n    supabaseTable = 'trips'; isNewRecord = false;\n    supabasePayload = JSON.stringify({ trip_status: 'arrived' });\n  } else if (actionType === 'CANCEL') {\n    supabaseTable = 'trips'; isNewRecord = false;\n    supabasePayload = JSON.stringify({ trip_status: 'cancelled' });\n  } else if (actionType === 'PAYMENT_PAID') {\n    supabaseTable = 'trips'; isNewRecord = false;\n    commissionStatus = 'paid';\n    supabasePayload = JSON.stringify({\n      amount_paid: cleanNum(kv['AMOUNT']),\n      commission_status: 'paid',\n      payment_status: 'paid'\n    });\n  } else if (actionType === 'ALL_COMMISSION_PAID') {\n    supabaseTable = 'trips'; isNewRecord = false; isAllPaid = true;\n    lorryNumber = '';\n    commissionStatus = 'paid';\n    supabasePayload = JSON.stringify({ commission_status: 'paid' });\n  }\n}\n\nreturn [{json: {\n  replyText: replyText || 'OK',\n  hasAction, supabaseTable, supabasePayload,\n  lorryNumber, isNewRecord, isAllPaid,\n  tripDate, tripRate, tripCommission, commissionStatus,\n  brokerPhone: $('Parse Input').first().json.phone\n}}];"
      },
