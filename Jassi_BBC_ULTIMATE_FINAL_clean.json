    {
      "parameters": {
        "jsCode": "const input = $('Parse Input').first().json;\nlet history=[], trips=[], reminders=[], drivers=[], memory=[];\ntry { history = $('Get Lorry History').all().map(i=>i.json).filter(i=>i&&i.lorry_number); } catch(e){}\ntry { trips = $('Get Active Trips').all().map(i=>i.json).filter(i=>i&&i.lorry_number); } catch(e){}\ntry { reminders = $('Get Reminders').all().map(i=>i.json).filter(i=>i&&i.reminder_date); } catch(e){}\ntry { drivers = $('Get Drivers').all().map(i=>i.json).filter(i=>i&&i.name); } catch(e){}\ntry { memory = $('Fetch Memory').all().map(i=>i.json).filter(i=>i&&i.role); } catch(e){}\n\nlet historyContext = '';\nif (input.intent === 'HISTORY') {\n  if (history.length > 0) {\n    let tc=0, tp=0, tpaid=0;\n    history.forEach(h=>{\n      tc+=parseFloat(h.commission_amount||0);\n      if(h.commission_status==='paid') tpaid+=parseFloat(h.commission_amount||0);\n      else tp+=parseFloat(h.commission_amount||0);\n    });\n    historyContext = 'RECORDS('+history.length+'):'+JSON.stringify(history)+'|TOTAL_COMM:'+tc.toFixed(0)+'|PAID:'+tpaid.toFixed(0)+'|PENDING:'+tp.toFixed(0);\n  } else {\n    historyContext = input.lorryNumber ? 'No records for '+input.lorryNumber : 'No history found.';\n  }\n}\n\nconst systemPrompt = `You are Jassi, AI Manager BBC Bikaner Bangalore Carrier, Bangalore. Reply same language as broker (Hindi/English/Hinglish). No emojis. Short replies.\n\nGREETING: If intent GREETING reply ONLY: Sat Sri Akal Ji! Main Jassi aan, BBC di AI Manager. Dasao ki kaam hai?\n\nLOADING POINT RULE: loading_point is ALWAYS \"Bangalore\". Never ask. Never change it.\n\nBBC OFFICE MESSAGE FORMAT - When broker sends in this format:\nLine 1: Destination city (unloading point)\nLine 2: Lorry number (e.g. RJ19GE4481)\nLine 3: M.XXXXXXXXXX (driver mobile - remove M. prefix)\nLine 4: RATE.XXXXXX or just amount (rate/hire - ignore weight like 20.TN)\nExtract: lorry=line2, TO=line1, DPHONE=line3(remove M.), RATE=line4(numbers only), FROM=Bangalore always\nSave immediately. End with: ||ACTION:NEW_TRIP|LORRY:L|FROM:Bangalore|TO:city|RATE:amount|DPHONE:phone|DATE:today||\n\nIMAGE RULE: Read image text carefully. Extract trip details. Caption may say commission paid/pending/amount. Save accordingly. IMPORTANT: Kharcha means driver expense - do NOT record as commission. Commission is only what BBC receives from broker.\n\nDRIVER PHONE: If asked \"X lorry driver ka number\" - search trips data and give driver_phone for that lorry.\n\nCOMMISSION RULES:\n1. Always extract commission when mentioned\n2. \"commission paid AMOUNT for LORRY\" = mark that specific lorry trip paid\n3. \"all commission paid\" / \"sabka commission paid\" / \"sab paid\" = mark ALL active trips paid\n4. Show commission status in all history replies\n5. Pending commission = still to receive. Paid = already received.\n\nSAVE RULES:\n1. Never ask confirmation. Save immediately.\n2. Partial data ok. Null for missing.\n3. HISTORY: Each trip: Date|Route|Driver Phone|Rate|Commission|Status. Totals at end.\n4. NEW_TRIP last line ONLY: ||ACTION:NEW_TRIP|LORRY:L|FROM:Bangalore|TO:T|PARTY:P|RATE:R|DATE:D|ARRIVAL:A|COMMISSION:C|DPHONE:DP||\n5. NEW_DRIVER last line ONLY: ||ACTION:NEW_DRIVER|NAME:N|PHONE:P|TRUCK:T||\n6. ARRIVED last line ONLY: ||ACTION:ARRIVED|LORRY:L||\n7. CANCEL last line ONLY: ||ACTION:CANCEL|LORRY:L||\n8. PAYMENT per trip last line ONLY: ||ACTION:PAYMENT_PAID|LORRY:L|AMOUNT:A||\n9. ALL COMMISSIONS PAID last line ONLY: ||ACTION:ALL_COMMISSION_PAID||\n10. GENERAL short reply.\n\nDATA: INTENT=${input.intent} LORRY=${input.lorryNumber} TODAY=${input.today}${historyContext?' HISTORY='+historyContext:''} TRIPS=${JSON.stringify(trips.slice(0,10))} REMINDERS=${JSON.stringify(reminders.slice(0,5))} DRIVERS=${JSON.stringify(drivers.slice(0,10))}`;\n\nconst messages = [];\nmemory.slice(-18).forEach(m => { if (m.role && m.content) messages.push({role: m.role, content: String(m.content)}); });\n\nif (input.hasImage && input.fileId) {\n  try {\n    const filePath = $('Get File Path').first().json?.result?.file_path;\n    if (filePath) {\n      const imageUrl = `https://api.telegram.org/file/botYOUR_TELEGRAM_BOT_TOKEN_HERE/${filePath}`;\n      const response = await helpers.httpRequest({\n        method: 'GET',\n        url: imageUrl,\n        encoding: 'arraybuffer'\n      });\n      const base64Image = Buffer.from(response).toString('base64');\n      if (base64Image && base64Image.length > 100) {\n        messages.push({\n          role: 'user',\n          content: [\n            { type: 'image', source: { type: 'base64', media_type: 'image/jpeg', data: base64Image } },\n            { type: 'text', text: input.msg || 'Extract trip details from this image.' }\n          ]\n        });\n      } else {\n        messages.push({role: 'user', content: (input.msg||'') + ' [Image error. Please resend.]'});\n      }\n    } else {\n      messages.push({role: 'user', content: input.msg||''});\n    }\n  } catch(e) {\n    messages.push({role: 'user', content: (input.msg||'') + ' [Image error: ' + e.message + ']'});\n  }\n} else {\n  messages.push({role: 'user', content: input.msg});\n}\n\nconst requestBody = { model: 'claude-sonnet-4-6', max_tokens: 600, system: systemPrompt, messages: messages };\nreturn [{json: { brokerMessage: input.msg, brokerPhone: input.phone, intent: input.intent, lorryNumber: input.lorryNumber, requestBody: JSON.stringify(requestBody) }}];\n"
      },
