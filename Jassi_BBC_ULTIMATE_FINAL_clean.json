      "id": "00a9789c-7fb1-4eee-8c48-3cc737b109df",
      "name": "Get CRSL",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        -448,
        912
      ],
      "alwaysOutputData": true,
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst today = new Date().toLocaleDateString('en-IN');\nif (!items || items.length === 0) return [{json:{message:'No pending CRSL today. All clear.'}}];\nconst pending = items.filter(i => i.json && (i.json.lorry_number || i.json.commission_amount));\nif (pending.length === 0) return [{json:{message:'No pending CRSL today. All clear.'}}];\nlet total = 0;\nlet msg = 'BBC CRSL - '+today+'\\nPending commissions:';\npending.forEach(i => {\n  const d = i.json;\n  const flag = d.urgency_flag ? ' ** URGENT **' : '';\n  const comm = d.commission_amount || d.amount_pending || 0;\n  total += parseFloat(comm);\n  msg += '\\n'+(d.lorry_number||'?')+' | Rs.'+comm+' | Arrival: '+(d.arrival_date||d.expected_arrival_date||'TBD')+flag;\n});\nmsg += '\\n\\nTotal Pending: Rs.'+total.toFixed(0);\nreturn [{json:{message:msg}}];"
      },
