    {
      "parameters": {
        "jsCode": "const rawInput = $input.first().json;\nconst body = rawInput.body || rawInput;\nconst message = body.message || {};\nconst msg = message.text || message.caption || '';\nconst phone = String(message.chat?.id || message.from?.id || '');\nconst lower = msg.toLowerCase().trim();\nconst lines = msg.trim().split('\\n').map(l => l.trim()).filter(l => l);\nconst hasImage = !!(message.photo && message.photo.length > 0);\nconst fileId = hasImage ? message.photo[message.photo.length-1].file_id : null;\n\n// Detect BBC office format:\n// Line1=destination, Line2=lorry, Line3=M.phone, Line4=RATE.amount\nconst line2clean = (lines[1] || '').replace(/\\s+/g,'');\nconst isBBCFormat = lines.length >= 3 &&\n  /^[A-Z]{2}\\d{2}[A-Z]{1,3}\\d{4}$/i.test(line2clean) &&\n  lines.some(l => /^M\\./i.test(l.trim()) || /^RATE\\./i.test(l.trim()));\n\nconst cleanMsg = msg.replace(/\\s+/g,'');\nconst lorryMatch = cleanMsg.match(/[A-Z]{2}\\d{2}[A-Z]{1,3}\\d{4}/i);\nconst lorryNumber = lorryMatch ? lorryMatch[0].toUpperCase() : '';\n\nlet intent = 'GENERAL';\nconst greetWords = ['hi','hello','hey','hlo','sat sri akal','satsriakal','namaste','jai hind','good morning','good evening','waheguru','ssa'];\nif (greetWords.some(g => lower === g || lower.startsWith(g+' '))) intent = 'GREETING';\nelse if (isBBCFormat) intent = 'NEW_TRIP';\nelse if (lower.includes('history') || lower.includes('batao purana') || (lower.includes('record') && (lorryNumber || lower.includes('all') || lower.includes('sab')))) intent = 'HISTORY';\nelse if (lower.includes('load') || lower.includes('dispatch') || lower.includes('naya trip') || lower.includes('new trip')) intent = 'NEW_TRIP';\nelse if (lower.includes('new driver') || lower.includes('naya driver') || lower.includes('add driver')) intent = 'DRIVER';\nelse if ((lower.includes('all') || lower.includes('sab') || lower.includes('sabka')) && (lower.includes('commission') || lower.includes('payment')) && (lower.includes('paid') || lower.includes('clear') || lower.includes('ho gaya'))) intent = 'ALL_PAID';\nelse if (lower.includes('paid') || lower.includes('payment') || (lower.includes('commission') && (lower.includes('de') || lower.includes('diya') || lower.includes('mila') || lower.includes('paid') || lower.includes('ho gaya')))) intent = 'PAYMENT';\nelse if (lower.includes('pahunch') || lower.includes('arrived') || lower.includes('aa gaya') || lower.includes('reached') || lower.includes('pahuncha')) intent = 'ARRIVED';\nelse if (lower.includes('cancel')) intent = 'CANCEL';\nelse if (lower.includes('reminder') || lower.includes('crsl') || lower.includes('due')) intent = 'REMINDER';\nelse if (lower.includes('report') || lower.includes('weekly') || lower.includes('summary') || lower.includes('stats')) intent = 'REPORT';\nelse if (hasImage) intent = 'IMAGE';\n\nreturn [{ json: { msg, phone, lorryNumber, intent, today: new Date().toLocaleDateString('en-IN'), fileId, hasImage, isBBCFormat, lines } }];"
      },
