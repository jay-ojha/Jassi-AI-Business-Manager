        "jsCode": "const phone = $('Parse Input').first().json.phone;\nconst userMsg = $('Parse Input').first().json.msg;\nconst replyText = $('Parse Reply').first().json.replyText;\nconst memoryBody = JSON.stringify([\n  {phone: phone, role: 'user', content: userMsg},\n  {phone: phone, role: 'assistant', content: replyText}\n]);\nreturn [{json: {memoryBody}}];"
