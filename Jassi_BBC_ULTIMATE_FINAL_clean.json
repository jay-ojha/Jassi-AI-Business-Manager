    {
      "parameters": {
        "jsCode": "const items=$input.all();\nlet trips=0,comm=0,paid=0,pending=0,paidList='',pendingList='';\nitems.forEach(i=>{\n  const d=i.json;\n  if(!d||!d.driver_name)return;\n  trips+=parseInt(d.trips_this_week||0);\n  comm+=parseFloat(d.commission_this_week||0);\n  paid+=parseFloat(d.paid_this_week||0);\n  pending+=parseFloat(d.pending_this_week||0);\n  if(parseFloat(d.paid_this_week||0)>0) paidList+='\\n- '+d.driver_name+': Rs.'+parseFloat(d.paid_this_week).toFixed(0);\n  if(parseFloat(d.pending_this_week||0)>0){\n    const r=d.risk_category==='red'?'[RED]':d.risk_category==='yellow'?'[YLW]':'[OK]';\n    pendingList+='\\n'+r+' '+d.driver_name+': Rs.'+parseFloat(d.pending_this_week).toFixed(0);\n  }\n});\nconst today=new Date().toLocaleDateString('en-IN');\nconst msg='Weekly Report BBC\\n'+today+'\\n\\nTrips: '+trips+'\\nTotal Commission: Rs.'+comm.toFixed(0)+'\\nPaid: Rs.'+paid.toFixed(0)+'\\nPending: Rs.'+pending.toFixed(0)+'\\n\\nPaid this week:'+(paidList||'\\nNone')+'\\\\n\\nPending:'+(pendingList||'\\nAll clear!');\nreturn [{json:{message:msg}}];"
      },
